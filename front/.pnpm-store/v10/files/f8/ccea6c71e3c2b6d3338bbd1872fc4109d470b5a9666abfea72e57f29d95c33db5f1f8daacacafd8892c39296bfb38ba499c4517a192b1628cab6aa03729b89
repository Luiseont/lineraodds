const userHasEmbeddedWalletForChain = ({ user, chain })=>{
    const hasEmbeddedWalletForChain = user.verifiedCredentials.some((vc)=>vc.walletProvider === sdkApiCore.WalletProviderEnum.EmbeddedWallet && vc.chain && getChainFromVerifiedCredentialChain.getChainFromVerifiedCredentialChain(vc.chain) === chain);
    return hasEmbeddedWalletForChain;
};

