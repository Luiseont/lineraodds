    const waasWalletProvider = getWalletProviderByKey.getWalletProviderByKey({
        walletProviderKey
    }, client);
    if (!waasWalletProvider || !isWaasWalletProvider(waasWalletProvider)) {
        throw new getWalletProviderByKey.NoWalletProviderFoundError({
            walletProviderKey
        });
    }
    await waasWalletProvider.createWalletAccount();
};

